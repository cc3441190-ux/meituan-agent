# mock = 本地模拟（公开 Demo 推荐）| live = 直连 LLM（仅本地调试）
VITE_PLANNER_MODE=mock

# ⚠️ VITE_* 会打进前端 bundle，密钥会暴露在浏览器 DevTools / 源码中。
# 公开演示请保持 mock；生产环境应通过服务端 API Route 代理 LLM，勿把 Key 放前端。
# VITE_LLM_API_KEY=你的密钥
# VITE_LLM_BASE_URL=https://api.deepseek.com/v1
# VITE_LLM_MODEL=deepseek-chat

# 业务后端（可选；留空则 POI/库存由 LLM 生成或 Mock 兜底）
# VITE_API_BASE_URL=
# VITE_API_TIMEOUT_MS=15000
